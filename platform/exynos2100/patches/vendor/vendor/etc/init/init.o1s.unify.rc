# SM-G991B
on early-init && property:ro.boot.em.model=SM-G991B
    # Firmware blobs
    mount none /vendor/firmware/SM-G991B/AP_AUDIO_SLSI.bin vendor/firmware/AP_AUDIO_SLSI.bin bind
    mount none /vendor/firmware/SM-G991B/APDV_AUDIO_SLSI.bin vendor/firmware/APDV_AUDIO_SLSI.bin bind
    mount none /vendor/firmware/SM-G991B/bcm4375B1_murata.hcd vendor/firmware/bcm4375B1_murata.hcd bind
    mount none /vendor/firmware/SM-G991B/bcm4375B1_semco.hcd vendor/firmware/bcm4375B1_semco.hcd bind
    mount none /vendor/firmware/SM-G991B/bcm4375B1_semco_sem.hcd vendor/firmware/bcm4375B1_semco_sem.hcd bind
    mount none /vendor/firmware/SM-G991B/calliope_sram.bin vendor/firmware/calliope_sram.bin bind
    mount none /vendor/firmware/SM-G991B/dsp_master.bin vendor/firmware/dsp_master.bin bind
    mount none /vendor/firmware/SM-G991B/is_rta.bin vendor/firmware/is_rta.bin bind
    mount none /vendor/firmware/SM-G991B/mfc_fw.bin vendor/firmware/mfc_fw.bin bind
    mount none /vendor/firmware/SM-G991B/nfc/libsn100u_fw.so vendor/firmware/libsn100u_fw.so bind
    mount none /vendor/firmware/SM-G991B/NPU.bin vendor/firmware/NPU.bin bind
    mount none /vendor/firmware/SM-G991B/nvram.txt_1rh_es43_b1 vendor/firmware/nvram.txt_1rh_es43_b1 bind
    mount none /vendor/firmware/SM-G991B/nvram.txt_CS01_semco_b1 vendor/firmware/nvram.txt_CS01_semco_b1 bind
    mount none /vendor/firmware/SM-G991B/rxse.bin vendor/firmware/rxse.bin bind
    mount none /vendor/firmware/SM-G991B/SoundBoosterParam.bin vendor/firmware/SoundBoosterParam.bin bind
    mount none /vendor/firmware/SM-G991B/vts.bin vendor/firmware/vts.bin bind
    # TEEgris
    mount none /vendor/tee/SM-G991B /vendor/tee bind

# SM-G991N
on early-init && property:ro.boot.em.model=SM-G991N
    # Firmware blobs
    mount none /vendor/firmware/SM-G991N/AP_AUDIO_SLSI.bin vendor/firmware/AP_AUDIO_SLSI.bin bind
    mount none /vendor/firmware/SM-G991N/APDV_AUDIO_SLSI.bin vendor/firmware/APDV_AUDIO_SLSI.bin bind
    mount none /vendor/firmware/SM-G991N/bcm4375B1_murata.hcd vendor/firmware/bcm4375B1_murata.hcd bind
    mount none /vendor/firmware/SM-G991N/bcm4375B1_semco.hcd vendor/firmware/bcm4375B1_semco.hcd bind
    mount none /vendor/firmware/SM-G991N/bcm4375B1_semco_sem.hcd vendor/firmware/bcm4375B1_semco_sem.hcd bind
    mount none /vendor/firmware/SM-G991N/calliope_sram.bin vendor/firmware/calliope_sram.bin bind
    mount none /vendor/firmware/SM-G991N/dsp_master.bin vendor/firmware/dsp_master.bin bind
    mount none /vendor/firmware/SM-G991N/is_rta.bin vendor/firmware/is_rta.bin bind
    mount none /vendor/firmware/SM-G991N/mfc_fw.bin vendor/firmware/mfc_fw.bin bind
    mount none /vendor/firmware/SM-G991N/nfc/libsn100u_fw.so vendor/firmware/libsn100u_fw.so bind
    mount none /vendor/firmware/SM-G991N/NPU.bin vendor/firmware/NPU.bin bind
    mount none /vendor/firmware/SM-G991N/nvram.txt_1rh_es43_b1 vendor/firmware/nvram.txt_1rh_es43_b1 bind
    mount none /vendor/firmware/SM-G991N/nvram.txt_CS01_semco_b1 vendor/firmware/nvram.txt_CS01_semco_b1 bind
    mount none /vendor/firmware/SM-G991N/rxse.bin vendor/firmware/rxse.bin bind
    mount none /vendor/firmware/SM-G991N/SoundBoosterParam.bin vendor/firmware/SoundBoosterParam.bin bind
    mount none /vendor/firmware/SM-G991N/vts.bin vendor/firmware/vts.bin bind
    # TEEgris
    mount none /vendor/tee/SM-G991N /vendor/tee bind

# Restart audioserver on post-fs-data
on post-fs-data
    restart audioserver
